<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ConnectionPathStyle" TargetType="Path">
        <Setter Property="Stroke" Value="White"/>
        <Setter Property="StrokeThickness" Value="4"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="StrokeThickness" Value="3"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="White"
                                  BlurRadius="14"
                                  ShadowDepth="0"
                                  Opacity="0.9"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="PortEllipseStyle" TargetType="Ellipse">

        <!-- Default -->
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Fill" Value="#FFB347"/>
        <!-- orange -->
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="0" ShadowDepth="0"/>
            </Setter.Value>
        </Setter>

        <!-- Hover -->
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">

                <Setter Property="Fill" Value="#FFD580"/>
                <Setter Property="Stroke" Value="White"/>
                <Setter Property="StrokeThickness" Value="2"/>

                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                Color="#FFFFAA"
                BlurRadius="12"
                ShadowDepth="0"
                Opacity="0.9"/>
                    </Setter.Value>
                </Setter>

                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                    </Setter.Value>
                </Setter>

            </Trigger>
        </Style.Triggers>

    </Style>
    <Style x:Key="NodeBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="LightGray"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="4"
                                  Color="Black"
                                  Opacity="0.7"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <DataTrigger Binding="{Binding Kind}" Value="Start">
                <Setter Property="BorderBrush" Value="DarkGreen"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Kind}" Value="End">
                <Setter Property="BorderBrush" Value="DarkRed"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Kind}" Value="NpcDialogue">
                <Setter Property="BorderBrush" Value="DarkBlue"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Kind}" Value="Answer">
                <Setter Property="BorderBrush" Value="Goldenrod"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Kind}" Value="PlayerDialogue">
                <Setter Property="BorderBrush" Value="Purple"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BorderThickness" Value="3"/>
            </DataTrigger>

        </Style.Triggers>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#3E3E42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="MaxWidth" Value="500"/>
    </Style>
</ResourceDictionary>