<Window x:Class="NarativeNodeGraph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NarativeNodeGraph.Views"
        xmlns:vm="clr-namespace:NarativeNodeGraph.ViewModels"
        Title="{Binding DisplayTitle}" 
        Width="800" Height="600">
    <views:GraphView DataContext="{Binding}" />
    <Window.InputBindings>
        <KeyBinding Key="S"
                Modifiers="Control"
                Command="{Binding SaveCommand}" />

        <KeyBinding Key="O"
                Modifiers="Control"
                Command="{Binding LoadCommand}" />
    </Window.InputBindings>
</Window>
